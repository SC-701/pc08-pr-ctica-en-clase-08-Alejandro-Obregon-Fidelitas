@page
@model Web.Pages.Productos.IndexModel
@{
}
<h1>Listado de productoss</h1>
<div class="container">
    <div class="text-center mb-4">
        <a type="button" class="btn btn-primary" asp-page="./Agregar">Nuevo Producto</a>
    </div>
    
    <div class="row">
    @if (Model.productos != null)
        {
            foreach (var producto in Model.productos)
            {  
                <div class="col-md-4 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@Html.DisplayFor(modelo => producto.Nombre)</h5>
                            <h6 class="card-subtitle mb-2 text-muted">Precio: @Html.DisplayFor(modelo => producto.Precio)</h6>
                            <p class="card-text">Stock: @Html.DisplayFor(modelo => producto.Stock )</p>
                            <a type="button" class="btn btn-primary" asp-page="./Detalle" asp-route-id="@producto.Id">Detalles</a>
                            <a type="button" class="btn btn-warning" asp-page="./Editar" asp-route-id="@producto.Id">Editar</a>
                            <a type="button" class="btn btn-danger" asp-page="./Eliminar" asp-route-id="@producto.Id">Eliminar</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
